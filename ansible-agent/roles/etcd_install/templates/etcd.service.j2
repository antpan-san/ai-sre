[Unit]
Description=etcd
Documentation=https://github.com/coreos/etcd

[Service]
Type=notify
Restart=always
RestartSec=5s
LimitNOFILE=40000
TimeoutStartSec=0

ExecStart=/usr/local/bin/etcd \
  --name={{ inventory_hostname }} \
  --data-dir={{ etcd_data_dir }} \
  --listen-client-urls="https://{{ ansible_host }}:{{ etcd_client_port }}" \
  --advertise-client-urls="https://{{ ansible_host }}:{{ etcd_client_port }}" \
  --listen-peer-urls="https://{{ ansible_host }}:{{ etcd_peer_port }}" \
  --initial-advertise-peer-urls="https://{{ ansible_host }}:{{ etcd_peer_port }}" \
  --initial-cluster={{ etcd_initial_cluster }} \
  --initial-cluster-token={{ etcd_cluster_token }} \
  --initial-cluster-state={{ etcd_cluster_state }} \
  --cert-file={{ etcd_server_cert }} \
  --key-file={{ etcd_server_key }} \
  --trusted-ca-file={{ etcd_ca_cert }} \
  --client-cert-auth=true \
  --peer-cert-file={{ etcd_peer_cert }} \
  --peer-key-file={{ etcd_peer_key }} \
  --peer-trusted-ca-file={{ etcd_ca_cert }} \
  --peer-client-cert-auth=true \
  --heartbeat-interval={{ etcd_heartbeat_interval_ms | default(500) }} \
  --election-timeout={{ etcd_election_timeout_ms | default(5000) }} \
  --snapshot-count={{ etcd_snapshot_count | default(10000) }} \
  --quota-backend-bytes={{ etcd_quota_backend_bytes | default(8589934592) }} \
{% if etcd_unsafe_no_fsync | default(false) %}
  --unsafe-no-fsync=true \
{% endif %}
  --auto-compaction-mode=periodic \
  --auto-compaction-retention=1h

[Install]
WantedBy=multi-user.target

