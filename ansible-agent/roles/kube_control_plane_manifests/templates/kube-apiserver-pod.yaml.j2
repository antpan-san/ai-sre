apiVersion: v1
kind: Pod
metadata:
  name: kube-apiserver
  namespace: kube-system
  labels:
    tier: control-plane
    component: kube-apiserver
spec:
  hostNetwork: true
  priorityClassName: system-node-critical
  containers:
    - name: kube-apiserver
      image: {{ kube_apiserver_image }}
      imagePullPolicy: IfNotPresent
      command:
        - kube-apiserver
      args:
        - --advertise-address={{ hostvars[groups['kube_control_plane'][0]]['ansible_host'] }}
        - --bind-address=0.0.0.0
        - --secure-port=6443
        - --service-cluster-ip-range={{ service_cluster_ip_range }}
        - --etcd-servers={% for host in groups['etcd'] %}https://{{ hostvars[host]['ansible_host'] }}:2379{% if not loop.last %},{% endif %}{% endfor %}
        - --etcd-cafile={{ k8s_cert_dir }}/etcd_ca.crt
        - --etcd-certfile={{ k8s_cert_dir }}/etcd_client.crt
        - --etcd-keyfile={{ k8s_cert_dir }}/etcd_client.key
        - --tls-cert-file={{ k8s_cert_dir }}/apiserver.crt
        - --tls-private-key-file={{ k8s_cert_dir }}/apiserver.key
        - --client-ca-file={{ k8s_cert_dir }}/k8s_ca.crt
        - --anonymous-auth=false
        - --authorization-mode=Node,RBAC
        - --enable-admission-plugins=NodeRestriction
        - --service-account-issuer=https://kubernetes.default.svc.cluster.local
        - --service-account-signing-key-file={{ k8s_cert_dir }}/k8s_sa.key
        - --service-account-key-file={{ k8s_cert_dir }}/k8s_sa.pub
        - --kubelet-client-certificate={{ k8s_cert_dir }}/apiserver_kubelet_client.crt
        - --kubelet-client-key={{ k8s_cert_dir }}/apiserver_kubelet_client.key
        - --kubelet-certificate-authority={{ k8s_cert_dir }}/k8s_ca.crt
        - --allow-privileged=true
        - --v=2
      volumeMounts:
        - name: k8s-etc
          mountPath: /etc/kubernetes
          readOnly: true
  volumes:
    - name: k8s-etc
      hostPath:
        path: /etc/kubernetes
        type: Directory
