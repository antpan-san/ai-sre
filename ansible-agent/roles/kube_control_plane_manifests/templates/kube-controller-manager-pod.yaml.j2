apiVersion: v1
kind: Pod
metadata:
  name: kube-controller-manager
  namespace: kube-system
  labels:
    tier: control-plane
    component: kube-controller-manager
spec:
  hostNetwork: true
  priorityClassName: system-node-critical
  containers:
    - name: kube-controller-manager
      image: {{ kube_controller_manager_image }}
      imagePullPolicy: IfNotPresent
      command:
        - kube-controller-manager
      args:
        - --bind-address=127.0.0.1
        - --kubeconfig={{ k8s_base_dir }}/controller-manager.kubeconfig
        - --authentication-kubeconfig={{ k8s_base_dir }}/controller-manager.kubeconfig
        - --authorization-kubeconfig={{ k8s_base_dir }}/controller-manager.kubeconfig
        - --client-ca-file={{ k8s_cert_dir }}/k8s_ca.crt
        - --leader-elect=true
        - --cluster-name={{ cluster_name | string }}
        - --root-ca-file={{ k8s_cert_dir }}/k8s_ca.crt
        - --service-account-private-key-file={{ k8s_cert_dir }}/k8s_sa.key
        - --cluster-signing-cert-file={{ k8s_cert_dir }}/k8s_ca.crt
        - --cluster-signing-key-file={{ k8s_cert_dir }}/k8s_ca.key
        - --use-service-account-credentials=true
        - --controllers=*,bootstrap-signer-controller,token-cleaner-controller
        - --service-cluster-ip-range={{ service_cluster_ip_range }}
        - --allocate-node-cidrs=true
        - --cluster-cidr={{ pod_cluster_cidr }}
        - --v=2
      volumeMounts:
        - name: k8s-etc
          mountPath: /etc/kubernetes
          readOnly: true
  volumes:
    - name: k8s-etc
      hostPath:
        path: /etc/kubernetes
        type: Directory
