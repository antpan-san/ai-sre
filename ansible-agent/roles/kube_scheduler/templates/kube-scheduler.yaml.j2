apiVersion: kubescheduler.config.k8s.io/v1
kind: KubeSchedulerConfiguration

# 仅使用当前 apiVersion 支持的字段；顶层勿写 healthzBindAddress/metricsBindAddress 等，否则 strict 解码会失败。

clientConnection:
  kubeconfig: {{ k8s_base_dir }}/kube-scheduler.kubeconfig

leaderElection:
  leaderElect: true

profiles:
- schedulerName: default-scheduler

