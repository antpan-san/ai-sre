apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority: {{ k8s_cert_dir }}/k8s_ca.crt
    server: {{ k8s_api_server }}
  name: kubernetes
contexts:
- context:
    cluster: kubernetes
    user: kubelet
  name: default
current-context: default
users:
- name: kubelet
  user:
    client-certificate: {{ k8s_cert_dir }}/kubelet-client.crt
    client-key: {{ k8s_cert_dir }}/kubelet-client.key
