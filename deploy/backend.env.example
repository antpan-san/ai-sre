# /etc/opsfleet/backend.env — systemd EnvironmentFile（可选）
# 与 ft-backend/conf/config.yaml 配合：同一项若两处都配置，**环境变量优先**。
# 非密钥、非路径类运维项请优先写入 config.yaml，便于版本管理与 Code Review。

# --- 密钥（仅放环境变量，勿写入 config.yaml 并提交）---
# OPSFLEET_AI_API_KEY=sk-...
# OPSFLEET_AUTO_ITERATION_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=...
# OPSFLEET_AUTO_ITERATION_ENABLED=true
# OPSFLEET_JWT_ACCESS_TOKEN_EXP=1440

# --- 部署机路径（全栈 deploy-opsfleet-remote.sh 会自动写入，一般无需手改）---
# OPSFLEET_AISRE_BINARY_PATH=/root/sre/bin/ai-sre
# OPSFLEET_AISRE_BINARY_PATH_ARM64=/root/sre/bin/ai-sre.arm64
# OPSFLEET_AISRE_VERSION=0.5.16
# OPSFLEET_AI_SKILL_DATA_DIR=/var/lib/opsfleet/ai-skills
# OPSFLEET_K8S_MIRROR_BASE_URL=http://192.168.56.11

# --- 临时覆盖 config.yaml（调试用；稳定后应回写到 yaml）---
# OPSFLEET_SKILL_AUTO_REFINE=1
# OPSFLEET_SKILL_AUTO_REFINE_MIN_SAMPLES=8
# OPSFLEET_SKILL_AUTO_REFINE_COOLDOWN=12h
# OPSFLEET_SKILL_AUTO_REFINE_TOPICS=go_runtime,k8s
# OPSFLEET_SKILL_AUTO_REFINE_MAX_PER_DAY=3
