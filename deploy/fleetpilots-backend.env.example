# /etc/fleetpilots-backend.env — systemd EnvironmentFile（可选，与 /etc/opsfleet/backend.env 并存）
# 供 DeepSeek 兼容 LLM；密钥勿提交 Git。复制到实验室/生产后 chmod 600。
#
# 与 OPSFLEET_AI_* 等价（若两处都配置，OPSFLEET_AI_* 优先）：
#   DEEPSEEK_API_KEY     ↔ OPSFLEET_AI_API_KEY
#   DEEPSEEK_BASE_URL    ↔ OPSFLEET_AI_BASE_URL  （可写 https://api.deepseek.com，后端自动补 /v1）
#   DEEPSEEK_MODEL       ↔ OPSFLEET_AI_MODEL

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
