# 复制到 /etc/opsfleet/k8s-mirror.env 并由 systemd 或手动 source
# 与 ansible-agent/inventory/group_vars/all.yml 保持版本一致

export MIRROR_ROOT="${MIRROR_ROOT:-/var/lib/opsfleet-k8s-mirror}"
# manifest.json 中的下载 URL 前缀（与 download_domain 一致）
export PUBLIC_BASE_URL="${PUBLIC_BASE_URL:-http://192.168.56.11}"

# Kubernetes 服务端二进制（与 group_vars kubernetes_version / arch_version 对齐）
export KUBERNETES_VERSION="${KUBERNETES_VERSION:-v1.35.0}"
export KUBERNETES_ARCHS="${KUBERNETES_ARCHS:-amd64 arm64}"

# etcd
export ETCD_VERSION="${ETCD_VERSION:-v3.6.7}"
export ETCD_ARCHS="${ETCD_ARCHS:-amd64 arm64}"

# CNI plugins
export CNI_PLUGINS_VERSION="${CNI_PLUGINS_VERSION:-v1.9.0}"
export CNI_ARCHS="${CNI_ARCHS:-amd64 arm64}"

# 上游（公网拉取后写入 MIRROR_ROOT；仅内网节点访问本机 HTTP）
export K8S_UPSTREAM="${K8S_UPSTREAM:-https://dl.k8s.io}"
export ETCD_UPSTREAM="${ETCD_UPSTREAM:-https://github.com/etcd-io/etcd/releases/download}"
export CNI_UPSTREAM="${CNI_UPSTREAM:-https://github.com/containernetworking/plugins/releases/download}"
