[Unit]
Description=OpsFleet K8s artifact mirror (on-demand fetch + persistent cache)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/opsfleet/k8s-mirror.env
Environment=LISTEN=127.0.0.1:8090
ExecStart=/usr/local/bin/opsfleet-k8s-mirror-serve
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
