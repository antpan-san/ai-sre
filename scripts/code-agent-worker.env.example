# Copy to scripts/code-agent-worker.env (gitignored) and fill in secrets.
# Local code-agent worker — runs on THIS machine against OpsFleet API.

# OpsFleet API base (must include /ft-api suffix)
OPSFLEET_API_URL=http://192.168.56.11:9080/ft-api

# Same value as ft-backend OPSFLEET_CODE_AGENT_TOKEN or auto_iteration.code_agent_token
OPSFLEET_CODE_AGENT_TOKEN=

# ai-sre monorepo root on this machine
REPO_ROOT=/root/sre

# Cursor Agent CLI (agent login or CURSOR_API_KEY required)
AGENT_BIN=agent
# AGENT_MODEL=composer-2

# Poll interval when idle (seconds)
POLL_INTERVAL=30

# After agent succeeds, run remote smoke (1=yes, 0=no)
RUN_POST_VERIFY=1

# Optional: skip agent and only run verify (debug)
# DRY_RUN_AGENT=0
